        "\n",
        "import numpy as np\n",
        "\n",
        "# Rows = Months (Jan, Feb, Mar)\n",
        "# Columns = Products (Electronics, Apparel, Home Goods)\n",
        "sales_matrix = np.array([\n",
        "    [5000, 3200, 1500],  # Jan sales\n",
        "    [6200, 2900, 1800],  # Feb sales\n",
        "    [5800, 4100, 2200]   # Mar sales\n",
        "])\n",
        "\n",
        "# Calculate total revenue across all products and months\n",
        "grand_total = np.sum(sales_matrix)\n",
        "\n",
        "# Calculate monthly revenue across all products (sum horizontally across rows)\n",
        "monthly_totals = np.sum(sales_matrix, axis=1)\n",
        "\n",
        "# Calculate product revenue over the entire quarter (sum vertically down columns)\n",
        "product_totals = np.sum(sales_matrix, axis=0)\n",
        "\n",
        "print(f\"Grand Total Revenue: ${grand_total}\")\n",
        "print(f\"Total Sales by Month (Jan, Feb, Mar): {monthly_totals}\")\n",
